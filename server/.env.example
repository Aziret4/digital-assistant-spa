# Порт, на котором запускается сервер
PORT=5000

# --- Локальное подключение к PostgreSQL (для разработки) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=digital_assistant

# --- ИЛИ облачное подключение через connection string (для production, Neon/Render) ---
# Если эта переменная задана, то DB_HOST/DB_PORT/... игнорируются, и используется SSL.
# DATABASE_URL=postgresql://user:password@host/database

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# --- CORS ---
# URL фронтенда. Можно несколько через запятую. Если не задан — разрешены все origin'ы.
# CLIENT_URL=https://your-app.vercel.app
